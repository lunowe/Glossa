# Glossa server
GLOSSA_MONGO_URI=mongodb://localhost:27017
GLOSSA_MONGO_DB=glossa

GLOSSA_MINIO_ENDPOINT=localhost:9000
GLOSSA_MINIO_ACCESS_KEY=glossa
GLOSSA_MINIO_SECRET_KEY=glossa-secret
GLOSSA_MINIO_BUCKET=glossa-spaces
GLOSSA_MINIO_SECURE=false

GLOSSA_API_HOST=0.0.0.0
GLOSSA_API_PORT=8200

# ===========================================================================
# LLM (all inference runs through Pydantic AI)
# ---------------------------------------------------------------------------
# Pick one default provider + model; spaces can override per-space via their
# llm_config. Provider is one of: anthropic | openai | gemini | bedrock | vertex.
GLOSSA_DEFAULT_LLM_PROVIDER=openai
GLOSSA_DEFAULT_LLM_MODEL=gpt-4o-mini

# --- Per-provider API keys -------------------------------------------------
# Set the key(s) for the provider(s) you use. A space uses the key for its
# resolved provider unless it sets llm_config.api_key_ref explicitly.
GLOSSA_ANTHROPIC_API_KEY=
GLOSSA_OPENAI_API_KEY=
GLOSSA_GEMINI_API_KEY=

# OpenAI-compatible servers (Azure, OpenRouter, Groq, vLLM, Ollama, …): point the
# openai provider at a custom base URL. Leave blank for api.openai.com.
GLOSSA_OPENAI_BASE_URL=

# --- AWS Bedrock -----------------------------------------------------------
# Region is required. Provide static credentials OR a Bedrock bearer token, OR
# leave creds blank to use the host's default AWS chain (env vars, ~/.aws, IAM).
GLOSSA_AWS_REGION=
GLOSSA_AWS_ACCESS_KEY_ID=
GLOSSA_AWS_SECRET_ACCESS_KEY=
GLOSSA_AWS_SESSION_TOKEN=
GLOSSA_BEDROCK_API_KEY=

# --- Google Vertex AI ------------------------------------------------------
# Uses Application Default Credentials unless a service account JSON file is
# given. Project/location target the Vertex endpoint.
GLOSSA_VERTEX_PROJECT=
GLOSSA_VERTEX_LOCATION=us-central1
GLOSSA_VERTEX_SERVICE_ACCOUNT_FILE=

# --- Anthropic-only tuning (adaptive thinking + prompt caching) ------------
GLOSSA_ANTHROPIC_EFFORT=high
GLOSSA_ANTHROPIC_MAX_TOKENS=16000
GLOSSA_ANTHROPIC_ENABLE_THINKING=true

GLOSSA_INGEST_MAX_SOURCE_CHARS=200000

# Document upload ("upload" sources). Raw files are stored in object storage and
# parsed to text with LiteParse (https://github.com/run-llama/liteparse) during
# ingest. PDFs parse natively; Office formats need LibreOffice, images need
# ImageMagick, OCR needs Tesseract installed on the host/image.
GLOSSA_INGEST_MAX_UPLOAD_BYTES=25000000
GLOSSA_LITEPARSE_OCR_ENABLED=false

# Link ingestion ("url" sources). The pasted link is fetched and the readable
# main content is converted to markdown (via trafilatura) during ingest.
GLOSSA_URL_FETCH_TIMEOUT_SECONDS=30
GLOSSA_URL_FETCH_USER_AGENT=GlossaBot/0.1 (+https://github.com/glossa/glossa)

# MCP client/server helper configuration.
GLOSSA_BASE_URL=http://localhost:8200
GLOSSA_DEFAULT_SPACE_ID=
GLOSSA_API_TOKEN=

# Obsidian sync helper configuration.
GLOSSA_OBSIDIAN_VAULT=
GLOSSA_OBSIDIAN_SUBDIR=Glossa
GLOSSA_OBSIDIAN_PAGE_LIMIT=1000

# Optional extra keys for per-space llm_config.api_key_ref values. A space whose
# api_key_ref is "env:MY_OTHER_KEY" reads from that variable instead of the
# GLOSSA_*_API_KEY default for its provider. (The GLOSSA_* keys above cover the
# common case — you usually don't need these.)
# MY_OTHER_OPENAI_KEY=

# Dashboard + OAuth
GLOSSA_BASE_URL=http://localhost:8200
GLOSSA_SESSION_COOKIE_NAME=glossa_session
GLOSSA_SESSION_TTL_HOURS=168
GLOSSA_SESSION_COOKIE_SECURE=false
GLOSSA_GOOGLE_OAUTH_CLIENT_ID=
GLOSSA_GOOGLE_OAUTH_CLIENT_SECRET=
GLOSSA_GITHUB_OAUTH_CLIENT_ID=
GLOSSA_GITHUB_OAUTH_CLIENT_SECRET=
GLOSSA_OAUTH_STATE_TTL_MINUTES=10